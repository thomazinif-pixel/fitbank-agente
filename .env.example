# ============================================================
# MarIA V3 — Super Agente FitBank
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ------------------------------------------------------------
# OpenAI
# Obter em: https://platform.openai.com/api-keys
# Usado para: embeddings (text-embedding-3-small) + GPT-4o + GPT-4o-mini (classificador)
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# ------------------------------------------------------------
# Pinecone
# Obter em: https://app.pinecone.io → API Keys
# INDEX_HOST: encontre em Index > Connect (ex: https://fitbank-zendesk-xxx.svc.pinecone.io)
# ------------------------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_HOST=https://fitbank-zendesk-XXXXXXXX.svc.aped-XXXX-XXXX.pinecone.io
PINECONE_API_BASE=https://api.pinecone.io
PINECONE_INDEX_NAME=fitbank-zendesk

# ------------------------------------------------------------
# Upstash Redis (memória persistente por ticket)
# Criar em: https://console.upstash.com → Create Database
# Copiar: REST URL e REST Token da aba "REST API"
# Plano gratuito: 10.000 req/dia — suficiente para começar
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://XXXXXXXX.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu_token_upstash_aqui

# ------------------------------------------------------------
# Zendesk
# TOKEN: Admin Center → Apps e integrações → APIs → Tokens de API
# EMAIL: seu email de login no Zendesk
# SUBDOMAIN: a parte antes de .zendesk.com (ex: fitbank)
# ------------------------------------------------------------
ZENDESK_SUBDOMAIN=fitbank
ZENDESK_EMAIL=seu.email@fitbank.com.br
ZENDESK_API_TOKEN=seu_token_zendesk_aqui
